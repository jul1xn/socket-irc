<!doctype html>
<html lang="en" data-bs-theme="dark">

<head>
    <title>IRC Chat</title>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous" />
    <link rel="stylesheet" href="/css/fitting.css" />
    <link rel="stylesheet" href="/css/styles.css" />
</head>

<body>
    <main>
        <div class="container">
            <form id="connect-form" class="my-3">
                <div class="mb-3">
                    <label for="usernameInput" class="form-label">Username</label>
                    <input type="text" class="form-control" id="usernameInput">
                </div>
                <div class="mb-2">
                    <label for="passwordInput" class="form-label">Password</label>
                    <input type="password" class="form-control" id="passwordInput" disabled>
                </div>
                <div class="mb-3" id="registerPrompt" style="display: none;">
                    <a href="/register">Don't have an account?</a>
                </div>
                <div class="mb-3 form-check">
                    <input type="checkbox" class="form-check-input" id="guestAccount" checked>
                    <label class="form-check-label" for="guestAccount">Login as guest</label>
                </div>
                <div class="mb-3" id="status-alert-parent" style="display: none;">
                    <div class="alert alert-danger" role="alert" id="status-alert">
                        tung tung tung tung sahur
                    </div>
                </div>
                <button type="submit" class="btn btn-primary">Connect</button>
            </form>
        </div>
    </main>
    <script src="/js/storage.js"></script>
    <script src="/js/connect.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.8/dist/umd/popper.min.js"
        integrity="sha384-I7E8VVD/ismYTF4hNIPjVp/Zjvgyol6VFvRkX/vR+Vc4jQkC+hVqc2pM8ODewa9r"
        crossorigin="anonymous"></script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.min.js"
        integrity="sha384-BBtl+eGJRgqQAUMxJ7pMwbEyER4l1g+O15P+16Ep7Q9Q+zqX6gSbd85u4mG4QzX+"
        crossorigin="anonymous"></script>
</body>

</html>